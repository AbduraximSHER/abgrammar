{
    "quizzes": [
        {
            "id": "present-simple-basics",
            "topic": "present-simple",
            "title": "Present Simple - Quick Practice",
            "description": "Test your understanding of Present Simple",
            "passThreshold": 70,
            "questions": [
                {
                    "id": 1,
                    "type": "multiple-choice",
                    "question": "She ___ to school every day.",
                    "options": [
                        "go",
                        "goes",
                        "going",
                        "went"
                    ],
                    "correct": 1,
                    "explanation": "Use 'goes' (base verb + s) with 'she' because it's third person singular.",
                    "hint": "Think about third person singular"
                },
                {
                    "id": 2,
                    "type": "multiple-choice",
                    "question": "They ___ English at university.",
                    "options": [
                        "study",
                        "studies",
                        "studying",
                        "studied"
                    ],
                    "correct": 0,
                    "explanation": "Use 'study' (base form) with 'they' because it's plural. No 's' needed."
                },
                {
                    "id": 3,
                    "type": "fill-blank",
                    "question": "My brother ___ in a hospital. (work)",
                    "correct": [
                        "works"
                    ],
                    "explanation": "Use 'works' (base verb + s) with 'my brother' (he) because it's third person singular.",
                    "hint": "Add 's' for he/she/it"
                },
                {
                    "id": 4,
                    "type": "multiple-choice",
                    "question": "I ___ coffee every morning.",
                    "options": [
                        "drinks",
                        "drink",
                        "drinking",
                        "drank"
                    ],
                    "correct": 1,
                    "explanation": "Use 'drink' (base form) with 'I'. Don't add 's' for first person."
                },
                {
                    "id": 5,
                    "type": "fill-blank",
                    "question": "The sun ___ in the east. (rise)",
                    "correct": [
                        "rises"
                    ],
                    "explanation": "Use 'rises' (base verb + s) with 'the sun' (it) because it's third person singular. This is a general truth."
                }
            ]
        },
