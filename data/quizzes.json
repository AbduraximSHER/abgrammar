                    "question": "We ___ to the gym twice a week.",
                    "options": [
                        "goes",
                        "go",
                        "going",
                        "went"
                    ],
                    "correct": 1,
                    "explanation": "Use 'go' (base form) with 'we' (plural). No 's' needed for we/they."
                }
            ]
        },
